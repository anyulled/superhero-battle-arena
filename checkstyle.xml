<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java, xml, properties"/>

    <module name="TreeWalker">
        <module name="RegexpSinglelineJava">
            <property name="id" value="noFullyQualifiedNames"/>
            <property name="format" value="^(?!\s*(import|package) ).*\b(org\.barcelonajug\.superherobattlearena|org\.mockito|java\.util|java\.math|java\.time)\.([a-z0-9]+\.)*[A-Z][a-zA-Z0-9]*\b.*"/>
            <property name="message" value="Do not use fully qualified class names. Import the class instead."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Enforce static imports for common test libraries in test classes -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="requireStaticImportMockito"/>
            <property name="format" value="^(?!\s*import).*\bMockito\.(mock|when|verify|any|eq|times|never|atLeast|atMost)"/>
            <property name="message" value="Use static imports for Mockito methods instead of calling Mockito explicitly."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <module name="RegexpSinglelineJava">
            <property name="id" value="requireStaticImportAssertions"/>
            <property name="format" value="^(?!\s*import).*\bAssertions\.(assertThat|assertThatThrownBy|assertThatCode|assertEquals|assertTrue|assertFalse|assertNotNull|assertThrows)"/>
            <property name="message" value="Use static imports for Assertions methods instead of calling Assertions explicitly."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <module name="AvoidStarImport">
            <property name="allowClassImports" value="false"/>
            <property name="allowStaticMemberImports" value="true"/>
        </module>
        
        <!-- Error Handling Policy: Forbid printStackTrace. Use a logger instead. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="noPrintStackTrace"/>
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="message" value="Error Handling Policy: Do not use printStackTrace(). Use a Logger to log exceptions."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Error Handling Policy: Forbid System.out/err. Use a logger instead. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="noSystemOutErr"/>
            <property name="format" value="System\.(out|err)\.print"/>
            <property name="message" value="Error Handling Policy: Do not use System.out or System.err for logging. Use a Logger."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Error Handling Policy: Forbid catching generic Exception/Throwable/RuntimeException -->
        <module name="IllegalCatch">
            <property name="illegalClassNames" value="Exception, Throwable"/>
        </module>

        <!-- Error Handling Policy: Forbid throwing generic Exception/Throwable/RuntimeException -->
        <module name="IllegalThrows">
            <property name="illegalClassNames" value="Exception, Throwable"/>
            <property name="ignoredMethodNames" value="main"/>
        </module>

        <!-- Enable SuppressWarnings support -->
        <module name="SuppressWarningsHolder" />

        <module name="UnusedImports"/>
    </module>
    
    <!-- Enable SuppressWarningsFilter to read SuppressWarningsHolder -->
    <module name="SuppressWarningsFilter" />
</module>
